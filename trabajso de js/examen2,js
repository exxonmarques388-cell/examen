
    class Restaurante {
    #hamburguesaSencilla = 15;
    #hamburguesaConQueso = 18;
    #hamburguesaEspecial = 20;
    #papasFritas = 8;
    #refresco = 5;
    #postre = 6;

    mesa;
    pedidos = [];
    total = 0;

    agregar(opcion) {
        switch(opcion) {
            case 1:
                this.pedidos.push("Hamburguesa sencilla");
                this.total += this.#hamburguesaSencilla;
                break;
            case 2:
                this.pedidos.push("Hamburguesa con queso");
                this.total += this.#hamburguesaConQueso;
                break;
            case 3:
                this.pedidos.push("Hamburguesa especial");
                this.total += this.#hamburguesaEspecial;
                break;
            case 4:
                this.pedidos.push("Papas fritas");
                this.total += this.#papasFritas;
                break;
            case 5:
                this.pedidos.push("Refresco");
                this.total += this.#refresco;
                break;
            case 6:
                this.pedidos.push("Postre");
                this.total += this.#postre;
                break;
        }
    }
}

const pedidos = [];


let mesa1 = new Restaurante();
mesa1.mesa = 1;
mesa1.agregar(1);
mesa1.agregar(4);
mesa1.agregar(5);
pedidos.push(mesa1);


let mesa2 = new Restaurante();
mesa2.mesa = 2;
mesa2.agregar(2);
mesa2.agregar(3);
mesa2.agregar(6);
pedidos.push(mesa2);


for (let mesa of pedidos) {
    console.log(`Mesa ${mesa.mesa}`);
    for (let pedido of mesa.pedidos) {
        console.log(pedido);
    }
    console.log(`Total: $${mesa.total}\n`);
}
